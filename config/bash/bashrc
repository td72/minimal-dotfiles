#!/usr/bin/env bash
# ==============================================================================
# Bash 設定ファイル (bashrc)
# XDG Base Directory 仕様に準拠したミニマルな設定
# このファイルは対話的シェルが起動するたびに読み込まれる
# ==============================================================================

# ------------------------------------------------------------------------------
# XDG Base Directory の設定
# XDG仕様に基づき、設定・データ・状態・キャッシュの保存先を定義する
# これにより $HOME 直下にドットファイルが散らばるのを防ぐ
# ------------------------------------------------------------------------------
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"   # 設定ファイルの保存先
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"  # データファイルの保存先
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}" # 状態ファイルの保存先（ログや履歴など）
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"      # キャッシュファイルの保存先

# ------------------------------------------------------------------------------
# コマンド履歴の設定
# 履歴をXDGディレクトリに保存し、サイズや重複の扱いを制御する
# ------------------------------------------------------------------------------
export HISTFILE="$XDG_STATE_HOME/bash/history"  # 履歴ファイルのパス（XDG準拠）
export HISTSIZE=10000                            # メモリ上に保持する履歴の件数
export HISTFILESIZE=20000                        # ファイルに保存する履歴の最大件数
export HISTCONTROL=ignoreboth:erasedups          # スペース始まりのコマンドと重複を無視する

# 履歴ディレクトリが存在しなければ作成する
[[ ! -d "$XDG_STATE_HOME/bash" ]] && mkdir -p "$XDG_STATE_HOME/bash"

# ------------------------------------------------------------------------------
# プロンプトの設定
# starship がインストールされていればそちらを使い、
# なければシンプルな ユーザー名@ホスト名:ディレクトリ$ 形式で表示する
# ------------------------------------------------------------------------------
if command -v starship &> /dev/null; then
    eval "$(starship init bash)"
else
    PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
fi

# ------------------------------------------------------------------------------
# エイリアスの設定
# よく使うコマンドの省略形を定義する
# ------------------------------------------------------------------------------
alias ls='ls --color=auto'   # ファイル一覧を色付きで表示する
alias ll='ls -alF'           # 隠しファイルを含む詳細一覧（ファイルタイプ付き）
alias la='ls -A'             # .と..以外の隠しファイルも表示する
alias l='ls -CF'             # コンパクトな一覧表示（ファイルタイプ付き）
alias grep='grep --color=auto' # 検索結果のマッチ部分を色付きで表示する

# ------------------------------------------------------------------------------
# タブ補完の設定
# bash-completion がインストールされていれば読み込む
# コマンドやファイル名の補完がより賢くなる
# ------------------------------------------------------------------------------
if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
fi

# ------------------------------------------------------------------------------
# デフォルトエディタの設定
# git commit などのコマンドで使われるエディタを vim に設定する
# ------------------------------------------------------------------------------
export EDITOR='vim'   # CUI用のデフォルトエディタ
export VISUAL='vim'   # GUI用のデフォルトエディタ（ターミナルでは同じでOK）

# ------------------------------------------------------------------------------
# シェルオプションの設定
# Bashの動作をより便利にするオプションを有効にする
# ------------------------------------------------------------------------------
shopt -s histappend    # シェル終了時に履歴を上書きではなく追記する（複数端末で履歴が消えない）
shopt -s checkwinsize  # ウィンドウサイズ変更時に行と列の値を自動更新する
shopt -s cdspell       # cdコマンドのディレクトリ名のタイプミスを自動修正する
shopt -s dirspell      # タブ補完時のディレクトリ名のスペルミスを自動修正する
