#!/usr/bin/env bash
# ==============================================================================
# Bash プロファイル (bash_profile)
# ログインシェルとして起動した際に最初に読み込まれるファイル
# 主な役割は bashrc を読み込むこと
# ==============================================================================

# ------------------------------------------------------------------------------
# bashrc の読み込み
# bash_profile はログインシェルでのみ実行されるが、
# bashrc は対話的シェルで毎回実行される設定を含んでいる
# ログインシェルでも bashrc の設定が必要なため、ここで明示的に読み込む
#
# まず $HOME/.config/bash/bashrc を探し、なければ $XDG_CONFIG_HOME を使う
# これにより XDG_CONFIG_HOME が未設定でも正しく動作する
# ------------------------------------------------------------------------------
if [[ -f "$HOME/.config/bash/bashrc" ]]; then
    source "$HOME/.config/bash/bashrc"
elif [[ -f "$XDG_CONFIG_HOME/bash/bashrc" ]]; then
    source "$XDG_CONFIG_HOME/bash/bashrc"
fi
