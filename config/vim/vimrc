" ==============================================================================
" Vim 設定ファイル (vimrc)
" ミニマルな設定
" ==============================================================================

" ------------------------------------------------------------------------------
" 基本設定
" シンタックスハイライトとファイルタイプ検出を有効にする
" ------------------------------------------------------------------------------
syntax on                    " シンタックスハイライトを有効にする（コードに色が付く）
filetype plugin indent on    " ファイルタイプに応じたプラグインとインデント設定を有効にする

" ------------------------------------------------------------------------------
" エンコーディングと編集の基本設定
" 快適にコーディングするための基本的な設定
" ------------------------------------------------------------------------------
set encoding=utf-8           " 内部エンコーディングをUTF-8にする（日本語対応に必須）
set autoindent               " 改行時に前の行のインデントを引き継ぐ
set smartindent              " 構文に応じて自動的にインデントを調整する（{の後など）
set expandtab                " Tab キーでスペースを挿入する（タブ文字を使わない）
set tabstop=4                " タブ文字の表示幅を4スペースにする
set shiftwidth=4             " 自動インデントの幅を4スペースにする
set softtabstop=4            " Tab キーを押したときに挿入されるスペース数

" ------------------------------------------------------------------------------
" 表示に関する設定
" 行番号やカーソル位置の表示を設定する
" ------------------------------------------------------------------------------
set number                   " 行番号を表示する
set cursorline               " カーソルがある行をハイライトする（現在位置が分かりやすい）
set showmatch                " 対応する括弧を一瞬ハイライトする
set showcmd                  " 入力中のコマンドをステータスラインに表示する
set laststatus=2             " ステータスラインを常に表示する（0:非表示, 1:分割時のみ, 2:常時）

" ------------------------------------------------------------------------------
" 検索に関する設定
" インクリメンタルサーチと大文字小文字の扱いを設定する
" ------------------------------------------------------------------------------
set incsearch                " 文字を入力するたびにリアルタイムで検索する
set hlsearch                 " 検索結果をハイライト表示する
set ignorecase               " 検索時に大文字小文字を区別しない
set smartcase                " ただし大文字を含む場合は区別する（ignorecaseと併用）

" ------------------------------------------------------------------------------
" 補完とバッファの設定
" コマンドラインの補完メニューとバッファの扱いを設定する
" ------------------------------------------------------------------------------
set wildmenu                 " コマンドラインでTAB補完候補をメニュー表示する
set wildmode=longest:full,full  " 最長一致まで補完し、次のTABで候補を順に選択する
set hidden                   " バッファを保存せずに切り替えられるようにする（編集中でも別ファイルを開ける）
set backspace=indent,eol,start  " BackSpace キーでインデント・改行・挿入開始位置を削除可能にする

" ------------------------------------------------------------------------------
" マウスとスクロールの設定
" マウス操作を有効にし、スクロール時の余白を設定する
" ------------------------------------------------------------------------------
set mouse=a                  " すべてのモードでマウス操作を有効にする
set scrolloff=5              " スクロール時にカーソルの上下に最低5行の余白を確保する
set sidescrolloff=10         " 横スクロール時にカーソルの左右に最低10列の余白を確保する

" ------------------------------------------------------------------------------
" アンドゥの永続化
" ファイルを閉じて再度開いても、アンドゥ履歴が残るようにする
" 長期間のプロジェクトで過去の変更を取り消せるので非常に便利
" ------------------------------------------------------------------------------
set undofile

" ------------------------------------------------------------------------------
" 不可視文字の表示
" タブ文字や行末の余計なスペースを可視化する
" これによりフォーマットの問題を見つけやすくなる
" ------------------------------------------------------------------------------
set list
set listchars=tab:›\ ,trail:·,extends:›,precedes:‹,nbsp:·
" tab:›\    → タブ文字を「›」と空白で表示する
" trail:·   → 行末の余分なスペースを「·」で表示する
" extends:› → 右にはみ出している行を「›」で示す
" precedes:‹ → 左にはみ出している行を「‹」で示す
" nbsp:·    → ノーブレークスペースを「·」で表示する

" ------------------------------------------------------------------------------
" カラースキームの設定
" ダークモードを基本とし、True Color に対応させる
" termguicolors を有効にすることで、ターミナルでもGUI版と同じ色が使える
" ------------------------------------------------------------------------------
set background=dark
if has('termguicolors')
  set termguicolors
endif
