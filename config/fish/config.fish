# ==============================================================================
# Fish シェル設定ファイル
# XDG Base Directory 仕様に準拠したミニマルな設定
# Fish シェルが起動するたびにこのファイルが読み込まれる
# ==============================================================================

# ------------------------------------------------------------------------------
# XDG Base Directory の設定
# 各種ファイルの保存先を標準化し、ホームディレクトリをきれいに保つ
# ------------------------------------------------------------------------------
set -gx XDG_CONFIG_HOME $HOME/.config        # 設定ファイルの保存先
set -gx XDG_DATA_HOME $HOME/.local/share     # データファイルの保存先
set -gx XDG_STATE_HOME $HOME/.local/state    # 状態ファイルの保存先（ログや履歴など）
set -gx XDG_CACHE_HOME $HOME/.cache          # キャッシュファイルの保存先

# ------------------------------------------------------------------------------
# プロンプトの設定
# starship がインストールされていればそちらを使い、
# なければシンプルな ユーザー名@ホスト名:ディレクトリ$ 形式で表示する
# ------------------------------------------------------------------------------
if command -v starship &> /dev/null
    starship init fish | source
else
    function fish_prompt
        # ユーザー名を緑色で表示
        set_color green
        echo -n (whoami)
        # 区切りの@を通常色で表示
        set_color normal
        echo -n '@'
        # ホスト名を緑色で表示（-s で短縮形）
        set_color green
        echo -n (hostname -s)
        # 区切りの:を通常色で表示
        set_color normal
        echo -n ':'
        # カレントディレクトリを青色で表示（prompt_pwd で短縮表示）
        set_color blue
        echo -n (prompt_pwd)
        # プロンプト記号を通常色で表示
        set_color normal
        echo -n '$ '
    end
end

# ------------------------------------------------------------------------------
# エイリアスの設定
# よく使うコマンドの省略形を定義する
# ------------------------------------------------------------------------------
alias ls='ls --color=auto'     # ファイル一覧を色付きで表示する
alias ll='ls -alF'             # 隠しファイルを含む詳細一覧（ファイルタイプ付き）
alias la='ls -A'               # .と..以外の隠しファイルも表示する
alias l='ls -CF'               # コンパクトな一覧表示（ファイルタイプ付き）
alias grep='grep --color=auto' # 検索結果のマッチ部分を色付きで表示する

# ------------------------------------------------------------------------------
# デフォルトエディタの設定
# git commit などで使われるエディタを vim に設定する
# ------------------------------------------------------------------------------
set -gx EDITOR vim   # CUI用のデフォルトエディタ
set -gx VISUAL vim   # GUI用のデフォルトエディタ

# ------------------------------------------------------------------------------
# Fish シェルの挙動設定
# ------------------------------------------------------------------------------
set fish_greeting              # 起動時のグリーティングメッセージを無効にする（空文字で非表示）

# ------------------------------------------------------------------------------
# ページャの設定
# man コマンドなどで使われるページャの動作を制御する
# ------------------------------------------------------------------------------
set -gx LESS '-R'   # LESS でANSIカラーエスケープシーケンスを解釈する（色付き表示）
